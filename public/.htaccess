DirectoryIndex index.php

ErrorDocument 400 /system-pages/error.php?code=400
ErrorDocument 401 /system-pages/error.php?code=401
ErrorDocument 403 /system-pages/error.php?code=403
ErrorDocument 404 /system-pages/error.php?code=404
ErrorDocument 405 /system-pages/error.php?code=405
ErrorDocument 408 /system-pages/error.php?code=408
ErrorDocument 410 /system-pages/error.php?code=410
ErrorDocument 413 /system-pages/error.php?code=413
ErrorDocument 414 /system-pages/error.php?code=414
ErrorDocument 415 /system-pages/error.php?code=415
ErrorDocument 429 /system-pages/error.php?code=429
ErrorDocument 500 /system-pages/error.php?code=500
ErrorDocument 501 /system-pages/error.php?code=501
ErrorDocument 502 /system-pages/error.php?code=502
ErrorDocument 503 /system-pages/error.php?code=503
ErrorDocument 504 /system-pages/error.php?code=504

# SECURITY HEADERS START
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=()"
</IfModule>
# SECURITY HEADERS END

# STATIC ASSET CACHE START
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"

    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(webp|png|jpg|jpeg|ico|svg|css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>
# STATIC ASSET CACHE END
